        <type>MRC_API void</type>
        <definition>MRC_API void MR_straightenBoundary</definition>
        <argsstring>(MR_Mesh *mesh, MR_EdgeId bd, float minNeiNormalsDot, float maxTriAspectRatio, MR_FaceBitSet *newFaces)</argsstring>
