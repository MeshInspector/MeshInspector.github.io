</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>space</parametername>
</parameternamelist>
<parameterdescription>
<para>rank=1: unit normal to solution plane, rank=2: unit direction of solution line, rank=3: zero vector </para>
