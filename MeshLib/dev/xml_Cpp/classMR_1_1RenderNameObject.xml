        <type>Vector3f</type>
        <definition>Vector3f MR::RenderNameObject::nameUiPoint</definition>
        <argsstring></argsstring>
        <name>nameUiPoint</name>
        <qualifiedname>MR::RenderNameObject::nameUiPoint</qualifiedname>
        <briefdescription>
<para>The line attachment point. </para>
        </briefdescription>
        <detaileddescription>
<para>The name tag is displayed as a text bubble, attached to a specific point on the model with at most 2-segment line. The first segment offset is specified in 3d model coordinates, and the second offset is in screen coordinates. The offsets can be tiny, since any non-zero offset is automatically extended to make sure the text bubble doesn&apos;t overlap the attachment point. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="/home/runner/work/MeshLib/MeshLib/MeshLib/source/MRViewer/MRRenderNameObject.h" line="59" column="14" bodyfile="/home/runner/work/MeshLib/MeshLib/MeshLib/source/MRViewer/MRRenderNameObject.h" bodystart="59" bodyend="-1"/>
      </memberdef>
