        <definition> bool mrmeshpy.EdgeLengthMesh.flipEdge</definition>
        <argsstring>(self, EdgeId e)</argsstring>
        <name>flipEdge</name>
        <qualifiedname>mrmeshpy.EdgeLengthMesh.flipEdge</qualifiedname>
        <param>
          <type>self</type>
