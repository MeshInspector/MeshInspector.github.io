        <name>MR_cutAlongEdgeLoop_MR_MeshTopology</name>
        <param>
          <type><ref refid="MR2DContoursTriangulation_8h_1ad396cf7d4433c5ba7924776f5b379c9b" kindref="member">MR_MeshTopology</ref> *</type>
