@INCLUDE = DoxyfileBase

PROJECT_NAME           = "MeshLib C++ Docs"
LAYOUT_FILE            = ../MeshLib/doxygen/DoxygenLayoutCpp.xml
INPUT                  = ../MeshLib/source \
                         ../MeshLib/doxygen/APICppPage.dox
FILE_PATTERNS          = *.h \
                         *.dox
EXCLUDE                = ../MeshLib/source/OpenCTM \
                         ../MeshLib/source/MRMesh/miniply.h \
                         ../MeshLib/source/MRMesh/MRphmap.h \
                         ../MeshLib/source/MRDotNet* \
                         ../MeshLib/source/MRMeshC \
                         ../MeshLib/source/MeshLibC2 \
                         ../MeshLib/source/MRViewer/MRGladGlfw.h
EXCLUDE_PATTERNS       = imgui* \
                         MRPch* \
                         exports.h \
                         resource.h \
                         */MRTest*/*
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = MR_BIND_PREFERRED_NAME MR_CANONICAL_TYPEDEFS MRMESH_API MRSYMBOLMESH_API MRVIEWER_API MRIOEXTRAS_API MRVOXELS_API
SKIP_FUNCTION_MACROS   = YES


EXCLUDE_SYMBOLS        = Json std
HTML_OUTPUT            = html/Cpp
